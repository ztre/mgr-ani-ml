# Docker Compose variables only.
#
# This file is used by docker-compose for host path and container user mapping.
# Runtime business settings such as TMDB / Emby / auth password are persisted in
# ${AMM_ROOT_DIR}/data/.env after the app starts, and should be managed from Web UI.

# Docker runtime user mapping
PUID=1000
PGID=100

# Host bind mount root (data/logs/pending will be created under this dir)
AMM_ROOT_DIR=/app/amm-state

# Optional: manual-review log paths inside the container.
# These defaults already match current backend defaults and the Docker bind mount above.
# Usually there is no need to change them unless you want a custom pending layout.
AMM_PENDING_JSONL_PATH=/app/pending/pending.jsonl
AMM_UNPROCESSED_ITEMS_JSONL_PATH=/app/pending/unprocessed_items.jsonl
AMM_REVIEW_JSONL_PATH=/app/pending/review.jsonl
